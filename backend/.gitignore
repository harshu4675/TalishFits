.env.development
.env.test
.env.production
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
combined.log
error.log

# Runtime
pids/
*.pid
*.seed
*.pid.lock

# Build
dist/
build/

# Coverage
coverage/
*.lcov
.nyc_output/
lib-cov/

# Cache
.cache/
.eslintcache

# OS
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.sw?
*.swp

# Uploads (local)
uploads/
temp/
tmp/
public/uploads/

# SSL Certificates
*.pem
*.crt
*.key
*.p12

# TypeScript
*.tsbuildinfo
tsconfig.tsbuildinfo

# Render
.render/

# Testing
test-results/
__tests__/coverage/

# MongoDB dumps
dump/
*.bson

# Misc
